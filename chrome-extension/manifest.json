{
  "manifest_version": 3,
  "name": "ApplyOn Bot",
  "version": "1.0.0",
  "description": "Control your ApplyOn job application bot from Chrome",
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "48": "assets/icon48.png"
    }
  },
  "background": {
    "service_worker": "src/background/service_worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://localhost:*/*",
        "*://127.0.0.1:*/*",
        "https://applyon.app/*",
        "https://app.applyon.app/*"
      ],
      "js": ["src/content/webapp_bridge.ts"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.linkedin.com/*"],
      "js": [
        "src/content/linkedin_panel.ts"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.linkedin.com/jobs/*"],
      "js": ["src/content/linkedin_bot.ts"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "activeTab",
    "alarms"
  ],
  "host_permissions": [
    "*://localhost:*/*",
    "*://127.0.0.1:*/*",
    "*://*.linkedin.com/*",
    "https://*/*"
  ]
}
