# ── Database ──────────────────────────────────────────────────────────────────
# Local:      mysql+pymysql://root:PASSWORD@localhost:3306/easy-apply
# AWS RDS:    mysql+pymysql://admin:PASSWORD@your-rds-endpoint.rds.amazonaws.com:3306/applyflowai
DATABASE_URL=mysql+pymysql://root:@localhost:3306/easy-apply

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=change-me-in-production
JWT_ALG=HS256
JWT_EXPIRES_MIN=10080

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated extra origins allowed (in addition to localhost:5173)
# Production example: CORS_ORIGINS=http://12.34.56.78
CORS_ORIGINS=

# ── Storage ───────────────────────────────────────────────────────────────────
# Local:      ./storage/resumes
# Production: /home/ubuntu/app/storage/resumes
RESUME_STORAGE_DIR=./storage/resumes

# ── Agent mode ────────────────────────────────────────────────────────────────
# Set to true in production (AWS) so runs fail with a clear error when no
# Jobcook agent is connected, instead of trying to spawn the bot locally.
REQUIRE_AGENT=false

# ── Bot Python (optional) ─────────────────────────────────────────────────────
# Path to Python used when running the bot locally (no agent).
# Leave empty to use the current interpreter.
# Example: /path/to/.jobcook-venv/bin/python3
BOT_PYTHON=

# ── AI provider keys (optional) ───────────────────────────────────────────────
# If set, these override the API key stored in the dashboard config at run time.
OPENAI_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
